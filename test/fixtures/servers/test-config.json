{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NeuroLink Server Adapter Test Configurations",
  "description": "Default test configurations for server adapter testing across all supported frameworks",
  "version": "1.0.0",
  "_note": "FIXTURE STATUS: This fixture is prepared for use but not yet imported by any test files. The loadTestFixture utility in server-test-utils.ts can load this file. See docs-site/docs/server-tests/TESTING.md for intended usage patterns.",

  "frameworks": {
    "hono": {
      "port": 0,
      "host": "127.0.0.1",
      "basePath": "/api",
      "enableSwagger": false,
      "enableMetrics": false,
      "disableBuiltInHealth": false,
      "timeout": 30000,
      "cors": {
        "enabled": true,
        "origins": ["*"],
        "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
        "headers": ["Content-Type", "Authorization", "X-Request-ID"],
        "credentials": false,
        "maxAge": 86400
      },
      "rateLimit": {
        "enabled": false,
        "windowMs": 900000,
        "maxRequests": 100,
        "message": "Too many requests from this IP"
      },
      "bodyParser": {
        "enabled": true,
        "maxSize": "10mb",
        "jsonLimit": "10mb",
        "urlEncoded": true
      },
      "logging": {
        "enabled": false,
        "level": "info",
        "includeBody": false,
        "includeResponse": false
      }
    },

    "express": {
