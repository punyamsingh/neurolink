      "default": "./dist/music/index.js"
    },
    "./avatar": {
      "types": "./dist/avatar/index.d.ts",
      "import": "./dist/avatar/index.js",
      "default": "./dist/avatar/index.js"
    },
    "./image-gen": {
      "types": "./dist/image-gen/index.d.ts",
      "import": "./dist/image-gen/index.js",
      "default": "./dist/image-gen/index.js"
    },
    "./hitl": {
      "types": "./dist/hitl/index.d.ts",
      "import": "./dist/hitl/index.js",
      "default": "./dist/hitl/index.js"
    },
    "./evaluation": {
      "types": "./dist/evaluation/index.d.ts",
      "import": "./dist/evaluation/index.js",
      "default": "./dist/evaluation/index.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.js",
      "default": "./dist/workflow/index.js"
    },
    "./rag": {
      "types": "./dist/rag/index.d.ts",
