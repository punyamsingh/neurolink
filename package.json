    },
    "./files": {
      "types": "./dist/files/index.d.ts",
      "import": "./dist/files/index.js",
      "default": "./dist/files/index.js"
    },
    "./processors": {
      "types": "./dist/processors/index.d.ts",
      "import": "./dist/processors/index.js",
      "default": "./dist/processors/index.js"
    },
    "./processors/*": {
      "types": "./dist/processors/*.d.ts",
      "import": "./dist/processors/*.js",
      "default": "./dist/processors/*.js"
    },
    "./adapters/*": {
      "types": "./dist/adapters/*.d.ts",
      "import": "./dist/adapters/*.js",
      "default": "./dist/adapters/*.js"
    },
    "./livekit": {
      "types": "./dist/voice/livekit/index.d.ts",
      "import": "./dist/voice/livekit/index.js",
      "default": "./dist/voice/livekit/index.js"
    }
  },
