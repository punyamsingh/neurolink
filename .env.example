SAGEMAKER_INPUT_FORMAT=json
SAGEMAKER_OUTPUT_FORMAT=json
SAGEMAKER_MAX_TOKENS=2048
SAGEMAKER_TEMPERATURE=0.7
SAGEMAKER_TOP_P=0.9
